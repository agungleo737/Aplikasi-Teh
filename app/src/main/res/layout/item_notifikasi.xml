<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="15dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <FrameLayout
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/glass_back"
            android:backgroundTint="#F0F0F0">

            <ImageView
                android:id="@+id/iv_notif_icon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@drawable/chat"
                app:tint="#40513B" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_notif_judul"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pesanan Diproses"
                android:textStyle="bold"
                android:textColor="#40513B"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tv_notif_pesan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Teh Hijau Sencha lo lagi disiapin nih..."
                android:textSize="14sp"
                android:textColor="#666666"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_more"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_more"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#40513B"
            android:contentDescription="Menu" />

    </LinearLayout>
</androidx.cardview.widget.CardView>