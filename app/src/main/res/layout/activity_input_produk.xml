<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF8EE"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#40513B"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp">

        <ImageView
            android:id="@+id/btn_back_input"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="4dp"
            android:rotation="180"
            android:src="@drawable/pro6"
            android:contentDescription="Kembali" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:text="Tambah Produk Baru"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="25dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Varian Teh"
                android:textColor="#40513B"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/et_nama_teh"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="20dp"
                android:background="@android:drawable/editbox_background"
                android:hint="Masukkan nama teh"
                android:paddingHorizontal="15dp"
                android:inputType="text" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kategori"
                android:textColor="#40513B"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            <Spinner
                android:id="@+id/sp_kategori_teh"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="20dp"
                android:background="@android:drawable/editbox_background"
                android:paddingHorizontal="15dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Harga Produk"
                android:textColor="#40513B"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/et_harga_teh"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="20dp"
                android:background="@android:drawable/editbox_background"
                android:hint="Masukan harga"
                android:paddingHorizontal="15dp"
                android:inputType="number" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jumlah Stok Barang"
                android:textColor="#40513B"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/et_stok_teh"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="20dp"
                android:background="@android:drawable/editbox_background"
                android:hint="Masukan jumlah stok"
                android:paddingHorizontal="15dp"
                android:inputType="number" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Deskripsi Produk"
                android:textColor="#40513B"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/et_deskripsi_teh"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="100dp"
                android:background="@android:drawable/editbox_background"
                android:gravity="top|start"
                android:hint="Tulis deskripsi mengenai produk ini"
                android:inputType="textMultiLine"
                android:padding="15dp"
                android:layout_marginBottom="25dp" />
            <Button
                android:id="@+id/btn_pilih_thumbnail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pilih Foto Thumbnail (Card Kecil)"
                android:backgroundTint="#5C8A5C"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <ImageView
                android:id="@+id/img_preview_thumbnail"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:background="#E8E8E8"
                android:layout_marginBottom="12dp"/>
            <Button
                android:id="@+id/btn_pilih_full"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pilih Foto Detail (Halaman Detail)"
                android:backgroundTint="#3A6B3A"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <ImageView
                android:id="@+id/img_preview_full"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:background="#E8E8E8"
                android:layout_marginBottom="12dp"/>
            <Button
                android:id="@+id/btn_simpan_teh"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Simpan"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#40513B" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
